{% extends 'base.html.twig' %}

{% block title %}Hello VoitureController!{% endblock %}

{% block body %}
    <h1>Voiture</h1>

    <a href="{{ path('app_voiture_new') }}" class="btn btn-success my-3">Ajouter une voiture</a>

    <table class="table table-strepid text-center">
        <thead>
            <tr class="table-dark">
                <th>Id</th>
                <th>Agence</th>
                <th>Titre</th>
                <th>Marque</th>
                <th>Description</th>
                <th>Photo</th>
                <th>Prix</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
  
            <tr>
                <td>{{ voiture.id }}</td>
                <td>{{ voiture.agence.titre }}</td>
                <td>{{ voiture.titre }}</td>
                <td>{{ voiture.marque }}</td>
                <td>{{ voiture.description }}</td>
                <td>
                    <img src="{{ asset('img/voitures/' ~ voiture.photo ) }}" alt="{{voiture.photo}}" class="rounded mx-auto d-block img-fluid agenceImg">
                </td>
                
                <td>{{ voiture.prix }}</td>
                <td>
                    <a href="{{ path('app_voiture_show', {'id': voiture.id}) }}">show</a>
                    <a href="{{ path('app_voiture_edit', {'id': voiture.id}) }}">edit</a>
                </td>
            </tr>
      
        </tbody>
    </table>
{% endblock %}
